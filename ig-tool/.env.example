# Meta App credentials (get from developers.facebook.com → your app → App Settings → Basic)
IG_APP_ID=REPLACE_ME
IG_APP_SECRET=REPLACE_ME

# OAuth redirect URI — must match exactly what's set in the Meta app dashboard
# App Dashboard → Instagram → Instagram API with Instagram Login → OAuth redirect URIs
IG_REDIRECT_URI=https://your-domain.com/callback

# How many posts to fetch per run (max 200, default 50)
IG_MEDIA_LIMIT=50

# Days of account insights to fetch (default 30)
IG_INSIGHTS_DAYS=30
